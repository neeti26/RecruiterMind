# RecruiterMind Environment Variables
# Copy this to .env and fill in your keys

# Option 1: OpenAI (GPT-4o) — best quality
OPENAI_API_KEY=sk-...

# Option 2: Groq (Llama-3.3-70B) — fast and free tier available
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_...

# Note: If neither key is set, the system runs in rule-based mode
# (no LLM tournament reranking, but still uses 7-dimension scoring + embeddings)
